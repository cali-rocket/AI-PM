# Sensitive values must stay in local .env and must not be committed.
PERSONAL_TASKS_DATABASE_ID=your_notion_database_id
# Optional: "mock" (default), "mcp" (direct MCP), or "gpt_mcp" (GPT + MCP tool)
PERSONAL_TASKS_READER_MODE=mock
# Optional: Notion MCP endpoint (default: https://mcp.notion.com/mcp)
# NOTION_MCP_URL=https://mcp.notion.com/mcp
# Required when PERSONAL_TASKS_READER_MODE=mcp
# NOTION_MCP_ACCESS_TOKEN=your_notion_mcp_oauth_access_token
# Required when PERSONAL_TASKS_READER_MODE=gpt_mcp
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-5-mini
# Optional: default https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
