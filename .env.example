# Sensitive values must stay in local .env and must not be committed.
PERSONAL_TASKS_DATABASE_ID=your_notion_database_id
# Optional: "mock" (default) or "notion_api" (Notion REST API)
PERSONAL_TASKS_READER_MODE=mock
# To use real Notion API reader: PERSONAL_TASKS_READER_MODE=notion_api
# NOTION_INTERNAL_INTEGRATION_SECRET=secret_xxx
# Optional Notion API overrides
# NOTION_API_BASE_URL=https://api.notion.com
# NOTION_API_VERSION=2022-06-28
